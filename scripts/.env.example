# ===== 应用 =====
NODE_ENV=development
PORT=3000
API_PREFIX=api

# ===== PostgreSQL =====
DATABASE_URL=postgresql://esign:esign_pwd@localhost:5432/esign?schema=public

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== JWT =====
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_ACCESS_TTL=7200          # access token 有效期(秒)
JWT_REFRESH_TTL=604800       # refresh token 有效期(秒, 7天)

# ===== MinIO =====
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=esign
MINIO_PRESIGN_TTL=300        # 预签名URL有效期(秒)

# ===== 文件存储路径加密 (AES-256-GCM, 32字节hex=64字符) =====
STORAGE_KEY_ENC_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ===== 安全策略 =====
LOGIN_MAX_FAIL=5             # 登录失败上限
LOGIN_LOCK_MINUTES=15        # 锁定分钟数
UPLOAD_CONTRACT_MAX_MB=50
UPLOAD_SEAL_MAX_MB=5

# ===== 前端站点(拼签署链接用) =====
SIGN_LINK_BASE_URL=http://localhost:5173/sign
